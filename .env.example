# Polymarket CLOB
PRIVATE_KEY=0x...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=

# News API
NEWS_API_KEY=

# Anthropic Claude API (for Oracle agent)
ANTHROPIC_API_KEY=

# Bot Configuration
PORT=3000
BOT_INTERVAL_MS=90000
MAX_PORTFOLIO_EXPOSURE=0.25
MAX_SINGLE_POSITION=0.05
MIN_CONSENSUS_AGENTS=4
MIN_EDGE=0.07
MIN_MARKET_VOLUME=50000
BANKROLL=10000
DRY_RUN=true
LOG_LEVEL=info

# Vercel Cron Secret
CRON_SECRET=

# Persistence: "file" for localhost, "memory" for Vercel
PERSISTENCE_MODE=file
